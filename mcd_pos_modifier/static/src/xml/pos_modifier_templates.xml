<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-inherit="point_of_sale.ProductsWidget" t-inherit-mode="extension">
        <xpath expr="//ProductCard" position="attributes">
            <attribute name="class">pos.productViewMode + (product.mcd_pos_unavailable ? ' mcd-product-unavailable' : '')</attribute>
        </xpath>
    </t>

    <t t-inherit="point_of_sale.ProductScreen" t-inherit-mode="extension">
        <xpath expr="//t[@t-set-slot='details']" position="replace">
            <t t-set-slot="details">
                <button
                    t-if="line and this._mcdOrderlineCanCustomize(line)"
                    class="btn btn-sm btn-outline-primary mt-1 mcd-orderline-customize"
                    t-on-click.stop="() => this._mcdOpenModifierPopupForLine(line)">
                    🍔 Tùy chỉnh món
                </button>
                <div t-if="line and line.modifier_note" class="small text-muted mt-1">
                    <t t-esc="line.modifier_note"/>
                </div>
            </t>
        </xpath>
    </t>

    <t t-inherit="point_of_sale.PaymentScreenTop" t-inherit-mode="extension">
        <xpath expr="//div[contains(@class, 'top-content-center')]" position="after">
            <div class="mcd-service-type-toggle d-flex align-items-center gap-2 me-2">
                <span class="mcd-service-label">Hình thức</span>
                <button
                    type="button"
                    class="btn btn-sm"
                    t-att-class="mcdIsServiceType('eat_in') ? 'btn-success' : 'btn-outline-secondary'"
                    t-on-click="() => this.mcdSetServiceType('eat_in')">
                    Ăn tại chỗ
                </button>
                <button
                    type="button"
                    class="btn btn-sm"
                    t-att-class="mcdIsServiceType('take_out') ? 'btn-success' : 'btn-outline-secondary'"
                    t-on-click="() => this.mcdSetServiceType('take_out')">
                    Mang đi
                </button>
            </div>
        </xpath>
    </t>

    <t t-name="mcd_pos_modifier.ModifierPopup" owl="1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content p-3">

                <div class="modal-header">
                    <h4 class="modal-title">
                        <t t-esc="props.productName || props.title"/>
                    </h4>
                </div>

                <div class="modal-body">
                    <t t-if="visibleIngredients.length === 0">
                        <div class="text-muted text-center py-4">
                            Sản phẩm này chưa có công thức (BoM). Vui lòng cấu hình BoM trong Manufacturing.
                        </div>
                    </t>

                    <t t-else="">
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th>Nguyên liệu</th>
                                    <th class="text-end">Giá</th>
                                    <th class="text-center">Tùy chỉnh</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="visibleIngredients" t-as="ingredient" t-key="ingredient.bom_line_id">
                                    <tr>
                                        <td><t t-esc="ingredient.name"/></td>
                                        <td class="text-end text-nowrap">
                                            <t t-if="hasPrice(ingredient)">
                                                +<t t-esc="formatPrice(ingredient.price_unit)"/> đ
                                            </t>
                                            <t t-else="">—</t>
                                        </td>
                                        <td class="text-center">
                                            <div class="d-flex gap-1 justify-content-center flex-wrap">

                                                <t t-if="ingredient.allowed_actions.includes('remove')">
                                                    <button
                                                        class="btn btn-sm"
                                                        t-att-class="isSelected(ingredient, 'remove') ? 'btn-danger' : 'btn-outline-danger'"
                                                        t-att-disabled="isDisabled(ingredient, 'remove')"
                                                        t-on-click="() => this.toggleAction(ingredient, 'remove')">
                                                        Bỏ
                                                    </button>
                                                </t>

                                                <t t-if="ingredient.allowed_actions.includes('extra')">
                                                    <button
                                                        class="btn btn-sm"
                                                        t-att-class="isSelected(ingredient, 'extra') ? 'btn-success' : 'btn-outline-success'"
                                                        t-att-disabled="isDisabled(ingredient, 'extra')"
                                                        t-on-click="() => this.toggleAction(ingredient, 'extra')">
                                                        Thêm
                                                    </button>
                                                </t>

                                                <t t-if="ingredient.allowed_actions.includes('only')">
                                                    <button
                                                        class="btn btn-sm"
                                                        t-att-class="isSelected(ingredient, 'only') ? 'btn-primary' : 'btn-outline-primary'"
                                                        t-on-click="() => this.toggleAction(ingredient, 'only')">
                                                        Chỉ
                                                    </button>
                                                </t>

                                            </div>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <div class="mt-2 p-2 bg-light rounded" t-if="state.note">
                            <strong>Ghi chú:</strong> <t t-esc="state.note"/>
                        </div>
                        <div class="mt-1 fw-bold" t-if="state.priceExtra">
                            Phí thêm: +<t t-esc="formatPrice(state.priceExtra)"/> đ
                        </div>
                    </t>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" t-on-click="cancel">Hủy</button>
                    <button class="btn btn-primary" t-on-click="confirm">Xác nhận</button>
                </div>

            </div>
        </div>
    </t>

    <t t-name="mcd_pos_modifier.SizeChoicePopup" owl="1">
        <div class="modal-dialog modal-md">
            <div class="modal-content p-3">
                <div class="modal-header">
                    <h4 class="modal-title">
                        <t t-esc="props.groupName || props.title"/>
                    </h4>
                </div>

                <div class="modal-body">
                    <div class="mcd-size-choice-grid">
                        <t t-foreach="sortedProducts" t-as="product" t-key="product.id">
                            <button
                                type="button"
                                class="mcd-size-choice"
                                t-att-class="isSelected(product) ? 'is-selected' : ''"
                                t-on-click="() => this.selectProduct(product)">
                                <span class="mcd-size-choice__size">
                                    <t t-esc="sizeLabel(product)"/>
                                </span>
                                <span class="mcd-size-choice__price">
                                    <t t-esc="product.getFormattedUnitPrice()"/>
                                </span>
                            </button>
                        </t>
                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" t-on-click="cancel">Hủy</button>
                    <button class="btn btn-primary" t-on-click="confirm">Thêm vào đơn</button>
                </div>
            </div>
        </div>
    </t>

    <t t-name="mcd_pos_modifier.CustomizeButton" owl="1">
        <div class="control-button btn btn-light rounded-0 fw-bolder mcd-pos-customize-button" t-on-click="click">
            🍔 Tùy chỉnh
        </div>
    </t>

</templates>
