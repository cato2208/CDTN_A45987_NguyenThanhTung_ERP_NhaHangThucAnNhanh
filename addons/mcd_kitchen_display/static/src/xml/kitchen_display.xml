<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="mcd_kds.KitchenDisplay" owl="1">
    <div class="kds-root">

        <div class="kds-header">
            <div class="kds-header__title">
                <span class="kds-header__logo">🍔</span>
                <span>Kitchen Display</span>
            </div>
            <div class="kds-header__count">
                <t t-esc="state.orders.length"/> đơn đang chờ
            </div>
            <button
                class="kds-serve-btn"
                t-att-class="state.serving ? 'kds-serve-btn--busy' : ''"
                t-on-click="() => this.onServe(state.orders[0] &amp;&amp; state.orders[0].id)"
                t-att-disabled="state.serving or !state.orders.length">
                <t t-if="state.serving">⏳ Đang phục vụ…</t>
                <t t-else="">✅ SERVE</t>
            </button>
        </div>

        <div class="kds-grid" t-if="state.orders.length">
            <t t-foreach="state.orders" t-as="order" t-key="order.id">
                <div class="kds-card" t-att-class="order_first ? 'kds-card--oldest' : ''">

                    <div class="kds-card__header">
                        <span class="kds-card__order-num">#<t t-esc="order.name"/></span>
                        <span class="kds-badge" t-att-class="serviceClass(order.service_type)">
                            <t t-esc="serviceLabel(order.service_type)"/>
                        </span>
                    </div>

                    <div class="kds-card__items">
                        <t t-foreach="order.lines" t-as="line" t-key="line_index">
                            <div class="kds-item">
                                <span class="kds-item__qty"><t t-esc="line.qty"/></span>
                                <div class="kds-item__detail">
                                    <span class="kds-item__name"><t t-esc="line.product_name"/></span>
                                    <!-- FIX: hiển thị modifier_note nếu có -->
                                    <span t-if="line.modifier_note" class="kds-item__note">
                                        → <t t-esc="line.modifier_note"/>
                                    </span>
                                </div>
                            </div>
                        </t>
                        <div t-if="!order.lines.length" class="kds-item kds-item--empty">
                            (Không có món)
                        </div>
                    </div>

                    <div class="kds-timer" t-att-class="timerClass(order.order_time)">
                        <t t-esc="elapsed(order.order_time)"/>s
                    </div>

                </div>
            </t>
        </div>

        <div class="kds-empty" t-if="!state.orders.length">
            <div class="kds-empty__icon">✔</div>
            <div class="kds-empty__text">Tất cả đơn đã được phục vụ!</div>
        </div>

    </div>
</t>

</templates>
