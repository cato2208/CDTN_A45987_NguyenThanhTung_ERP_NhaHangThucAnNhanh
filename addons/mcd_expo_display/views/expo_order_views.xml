<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ── Sequence for auto order numbers ──────────────────────────────── -->
    <record id="seq_expo_order" model="ir.sequence">
        <field name="name">Expo Order</field>
        <field name="code">expo.order</field>
        <field name="prefix">EXPO-</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>

    <!-- ── Tree / List view ─────────────────────────────────────────────── -->
    <record id="view_expo_order_tree" model="ir.ui.view">
        <field name="name">expo.order.tree</field>
        <field name="model">expo.order</field>
        <field name="arch" type="xml">
            <tree string="Expo Orders" decoration-muted="state=='done'">
                <field name="name"/>
                <field name="service_type"/>
                <field name="order_time"/>
                <field name="state"
                       widget="badge"
                       decoration-success="state=='done'"
                       decoration-warning="state=='waiting'"/>
            </tree>
        </field>
    </record>

    <!-- ── Form view ────────────────────────────────────────────────────── -->
    <record id="view_expo_order_form" model="ir.ui.view">
        <field name="name">expo.order.form</field>
        <field name="model">expo.order</field>
        <field name="arch" type="xml">
            <form string="Expo Order">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="waiting,done"/>
                    <button name="action_done"
                                type="object"
                                string="Mark Served"
                                class="btn-primary"
                                invisible="state == 'done'"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="service_type" widget="radio"/>
                        </group>
                        <group>
                            <field name="order_time"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Items">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id"
                                        options="{'no_create': True}"
                                        context="{'display_default_code': False}"/>
                                    <field name="qty"/>
                                    <field name="product_name" column_invisible="True"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Action: standard list/form for admin ─────────────────────────── -->
    <record id="action_expo_order" model="ir.actions.act_window">
        <field name="name">Expo Orders</field>
        <field name="res_model">expo.order</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state','=','waiting')]</field>
        <field name="context">{'search_default_waiting': 1}</field>
    </record>

    <!-- ── Action: KDS live display screen ──────────────────────────────── -->
    <record id="action_expo_display" model="ir.actions.client">
        <field name="name">Expo Display Screen</field>
        <field name="tag">mcd_expo.ExpoDisplay</field>
    </record>

</odoo>
