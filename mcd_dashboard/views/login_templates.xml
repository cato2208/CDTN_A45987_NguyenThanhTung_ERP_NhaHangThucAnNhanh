<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Kept only to deactivate the old theme records that previously lived in mcd_dashboard. -->
    <template id="mcd_login_layout" inherit_id="web.login_layout" name="Disabled Old McDonald Login Layout" active="False">
        <xpath expr="//div[hasclass('container') and hasclass('py-5')]" position="inside"/>
    </template>

    <template id="mcd_login_form_text" inherit_id="web.login" name="Disabled Old McDonald Login Text" active="False">
        <xpath expr="//form" position="inside"/>
    </template>
</odoo>
