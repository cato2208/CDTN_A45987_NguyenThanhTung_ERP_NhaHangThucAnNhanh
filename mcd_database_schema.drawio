        <mxCell id="master_group" value="1. Du lieu nen" style="swimlane;html=1;whiteSpace=wrap;rounded=1;startSize=34;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=16;fontStyle=1;" vertex="1" parent="1">
