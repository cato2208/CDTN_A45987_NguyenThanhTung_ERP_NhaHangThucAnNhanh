        <mxCell id="dashboard_group" value="5. Dashboard DSS" style="swimlane;html=1;whiteSpace=wrap;rounded=1;startSize=34;fillColor=#f5f5f5;strokeColor=#666666;fontSize=16;fontStyle=1;" vertex="1" parent="1">
