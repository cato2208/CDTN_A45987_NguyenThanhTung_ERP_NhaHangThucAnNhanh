        <mxCell id="product_product" value="&lt;b&gt;product.product&lt;/b&gt;&lt;br&gt;San pham ban va nguyen lieu&lt;br&gt;id, name, category&lt;br&gt;list_price, standard_price" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=13;align=left;spacingLeft=10;" vertex="1" parent="master_group">
          <mxGeometry x="25" y="165" width="280" height="95" as="geometry" />
